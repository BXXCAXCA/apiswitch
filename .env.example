APISWITCH_LISTEN_HOST=127.0.0.1
APISWITCH_PORT=8080
APISWITCH_DATABASE_URL=sqlite:///./apiswitch.db
APISWITCH_AUTH_ENABLED=false
APISWITCH_ADMIN_AUTH_ENABLED=false
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APISWITCH_MASTER_KEY=
# Required when ADMIN_AUTH_ENABLED=true (or when serving the admin UI remotely).
APISWITCH_ADMIN_TOKEN=
APISWITCH_FILE_STORAGE_DIR=./apiswitch-files
APISWITCH_FILE_MAX_UPLOAD_BYTES=20971520
# Optional: a built Vue frontend is served from /ui when this directory contains index.html.
APISWITCH_FRONTEND_DIST_DIR=
APISWITCH_RELOAD=false
APISWITCH_STREAM_FAILURE_MODE=strict_compat_mode
# Optional override for Claude Code profile discovery/writes.
APISWITCH_CLAUDE_CONFIG_ROOT=
